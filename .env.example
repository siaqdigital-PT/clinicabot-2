# =============================================================================
# ClinicaBot — Variáveis de Ambiente
# Copiar para .env.local e preencher os valores
# =============================================================================

# Base de dados (Neon PostgreSQL — https://neon.tech)
DATABASE_URL="postgresql://user:password@host/clinicabot?sslmode=require"

# Auth (NextAuth.js v5)
# Gerar com: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (opcional — https://console.cloud.google.com)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Groq (https://console.groq.com)
GROQ_API_KEY="gsk_..."

# Email (Resend — https://resend.com)
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@clinicabot.pt"

# Storage (Vercel Blob — https://vercel.com/docs/storage/vercel-blob)
BLOB_READ_WRITE_TOKEN=""

# Cron Job (secret para proteger o endpoint de lembretes)
# Gerar com: openssl rand -hex 32
CRON_SECRET="your-cron-secret-here"

# URLs da aplicação
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_WIDGET_URL="http://localhost:5173"
