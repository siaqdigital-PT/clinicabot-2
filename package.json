{
  "name": "clinicabot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "db:generate": "pnpm --filter @clinicabot/db prisma generate",
    "db:push": "pnpm --filter @clinicabot/db prisma db push",
    "db:migrate": "pnpm --filter @clinicabot/db prisma migrate dev",
    "db:studio": "pnpm --filter @clinicabot/db prisma studio",
    "db:seed": "pnpm --filter @clinicabot/db db:seed",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "build:web": "npx prisma generate --schema packages/db/prisma/schema.prisma && cd apps/web && npx next build"
  },
  "devDependencies": {
    "next": "14.2.3",
    "prettier": "^3.2.5",
    "prisma": "5.22.0",
    "turbo": "^2.0.6",
    "typescript": "^5.4.5"
  },
  "pnpm": {
    "overrides": {
      "prisma": "5.22.0",
      "@prisma/client": "5.22.0",
      "undici": "5.28.4"
    }
  },
  "packageManager": "pnpm@9.1.4",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}